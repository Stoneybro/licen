# LICEN Orchestrator — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file with real keys.

# ── Key Exchange ──────────────────────────────────────────────────────────────
# secp256k1 private key for ECIES unsealing (same keypair used in NEXT_PUBLIC_ORCHESTRATOR_PUBLIC_KEY)
ORCHESTRATOR_PRIVATE_KEY=

# ── On-Chain ──────────────────────────────────────────────────────────────────
# Private key of the backendWallet (the address set in DataPolicy constructor)
BACKEND_WALLET_PRIVATE_KEY=

# Deployed DataPolicy contract address on 0G Testnet
OG_DATA_POLICY_ADDRESS=0x6Fe8B5E16df9E0Aaf5E3dDf0E39BFA66dA25bD0b

# 0G Testnet RPC URL
OG_EVM_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage Indexer RPC (for downloading and re-uploading datasets)
OG_INDEXER_RPC_URL=https://indexer-storage-testnet-standard.0g.ai

# ── Envio Indexer ─────────────────────────────────────────────────────────────
ENVIO_GRAPHQL_URL=https://indexer.dev.hyperindex.xyz/001fb92/v1/graphql

# ── LICEN Web App ─────────────────────────────────────────────────────────────
# Base URL of the LICEN Next.js app (for key envelope lookup)
LICEN_WEB_API_URL=http://localhost:3000

# Optional: shared secret for the /api/orchestrator/key-envelope route
# If set, the orchestrator must send: Authorization: Bearer <this value>
ORCHESTRATOR_API_SECRET=

# ── Polling ───────────────────────────────────────────────────────────────────
# How often to poll Envio for new Granted jobs
ORCHESTRATOR_POLL_MS=5000
# How often to poll 0G Compute for task status updates (30s recommended)
OG_TASK_POLL_MS=30000

# ── 0G Compute ────────────────────────────────────────────────────────────────
# Private key of the wallet funding compute jobs (must hold 0G tokens on testnet)
# Can be the same as BACKEND_WALLET_PRIVATE_KEY if that wallet is funded
OG_COMPUTE_PRIVATE_KEY=

# (Optional) Pin a specific provider address. If unset, auto-discovers first available.
OG_COMPUTE_PROVIDER_ADDRESS=

# Fine-tuning model (default: Qwen2.5-0.5B-Instruct — cheapest/fastest on testnet)
OG_COMPUTE_MODEL=Qwen2.5-0.5B-Instruct

# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL — use the UNPOOLED connection string (postgres-js is long-running)
# Get from your Vercel project's environment variables
DATABASE_URL=
