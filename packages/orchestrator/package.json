{
  "name": "orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "LICEN Backend Orchestrator — monitors AccessGranted events, unseals AES keys, dispatches 0G Compute jobs",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --import ./src/env.ts src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
